  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.json",
      "use": "@vercel/static"
    },
    {
      "src": "icons/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "\/(.*\\.(?:js|css|html|json|png|jpg|jpeg|svg|ico))",
      "dest": "\/$1"
    },
    {
      "src": "\/api\/(.*)",
      "dest": "server.js"
    },
    {
      "src": "\/(.*)",
      "dest": "\/index.html"
    }
  ]
    }
  ]
}
